10 REM KOZMOLOGY * GRACE E./SYSTEM6302
20 BORDER 0: PAPER 0: INK 7: CLS
30 PAPER 0: INK 7
40 LET D=1

50 REM TEXT 
60 CLS
70 PRINT AT 12,7;"YOUR EYES ARE OPEN."
80 BEEP D,3
90 PAUSE 50
100 CLS
 
110 REM CIRCLES
120 LET XC=128: LET YC=88
130 FOR R=5 TO 40 STEP 5
140 CIRCLE XC,YC,R
150 BEEP D,3+INT (RND*2)
160 NEXT R
170 FOR R=40 TO 5 STEP -5
180 CIRCLE XC,YC,R
190 BEEP D,3+INT (RND*2)
200 NEXT R
 
 210 REM GLITCH
 220 FOR N=1 TO 20
 230 FOR I=1 TO 300
 240 POKE 16384+INT (RND*6144),INT (RND*256)
 250 NEXT I
 260 BEEP 0.001,1+INT (RND*4)
 270 NEXT N
 
 280 STOP
